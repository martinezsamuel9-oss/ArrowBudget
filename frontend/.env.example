# =============================================================
# COTIZANTE — Variables de entorno del Frontend
# =============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena cada valor (nunca subas .env a GitHub)
# =============================================================

# --- SUPABASE ---
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- BACKEND (solo necesario cuando actives pagos) ---
# En desarrollo local: http://localhost:4000
# En producción: URL de tu servicio en Railway/Render
VITE_API_URL=http://localhost:4000

# --- STRIPE (solo necesario cuando actives pagos) ---
# Usa pk_test_... para pruebas, pk_live_... para producción
# Encuéntralo en: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- PAYPAL (solo necesario cuando actives pagos) ---
# Encuéntralo en: developer.paypal.com → Apps & Credentials
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
